   "source": [
    "### Étape 2: Créer un agent avec serveur distant"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\"\"\n",
    "Exemple complet d'un agent Travel avec serveur MCP distant:\n",
    "\n",
    "```python\n",
    "import asyncio\n",
    "from langchain.agents import create_agent\n",
    "from langchain_mcp_adapters.client import MultiServerMCPClient\n",
    "from langchain.messages import HumanMessage\n",
    "from langchain_openai import ChatOpenAI  # Pour plus de capacités\n",
    "from langgraph.checkpoint.memory import InMemorySaver\n",
    "from dotenv import load_dotenv\n",
    "import os\n",
    "\n",
    "async def main():\n",
    "    # Charger les variables d'environnement\n",
    "    load_dotenv()\n",
    "    \n",
    "    # Configuration du client MCP distant\n",
    "    client = MultiServerMCPClient(\n",
    "        {\n",
    "            \"travel_server\": {\n",
    "                \"transport\": \"streamable_http\",\n",
    "                \"url\": \"https://mcp.kiwi.com\"\n",
    "            }\n",
    "        }\n",
    "    )\n",
    "    \n",
    "    # Récupérer les tools\n",
    "    tools = await client.get_tools()\n",
    "    \n",
    "    # Initialiser le modèle (GPT-5 pour plus de puissance)\n",
    "    model = ChatOpenAI(\n",
    "        model=\"gpt-4o\",\n",
    "        api_key=os.getenv(\"OPENAI_API_KEY\")\n",
    "    )\n",
    "    \n",
    "    # Créer l'agent avec mémoire\n",
    "    agent = create_agent(\n",
    "        model=model,\n",
    "        tools=tools,\n",
    "        checkpointer=InMemorySaver(),\n",
    "        system_prompt=\"You are a travel agent. Help users find flights and plan trips. \"\n",
    "                      \"Be helpful and provide clear information.\"\n",
    "    )\n",
    "    \n",
    "    # Configuration de la conversation\n",
    "    config = {\"configurable\": {\"thread_id\": \"travel_agent_1\"}}\n",
    "    \n",
    "    # Questions de voyage\n",
    "    travel_queries = [\n",
    "        \"Get me a direct flight from Rabat to Agadir on August 31st\",\n",
    "        \"Find the cheapest flight from Paris to Tokyo next month\",\n",
    "        \"Show me round-trip flights from Madrid to Barcelona\"\n",
    "    ]\n",
    "    \n",
    "    for query in travel_queries:\n",
    "        print(f\"\\nQuery: {query}\")\n",
    "        response = await agent.ainvoke(\n",
    "            {\"messages\": [HumanMessage(content=query)]},\n",
    "            config\n",
    "        )\n",
    "        print(f\"Response: {response['messages'][-1].content}\")\n",
    "\n",
    "# Exécuter\n",
    "asyncio.run(main())\n",
    "```\n",
    "\n",
    "Pour exécuter: `uv run --active python agent_travel_mcp.py`\n",
    "\"\"\")\n",
    "\n",
    "print(\"\\n✨ Avantages des serveurs MCP distants:\")\n",
    "print(\"  🌐 Accès à des services externes\")\n",
    "print(\"  📊 Données en temps réel\")\n",
    "print(\"  🔒 Sécurité (pas de données locales)\")\n",
    "print(\"  🚀 Scalabilité (serveurs distants)\")"
   ]
