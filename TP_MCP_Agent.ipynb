    "    \n",
    "    # Initialiser le modèle\n",
    "    model = ChatOllama(\n",
    "        model=\"llama3.2:3b\",\n",
    "        temperature=0\n",
    "    )\n",
    "    \n",
    "    # Créer l'agent\n",
    "    agent = create_agent(\n",
    "        model=model,\n",
    "        tools=tools,\n",
