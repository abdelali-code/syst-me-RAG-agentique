   "source": [
    "## 📌 PARTIE 1: Serveur MCP Local\n",
    "\n",
    "### Architecture:\n",
    "```\n",
    "┌─────────────────┐\n",
    "│  Python Script  │  ← Votre code\n",
    "└────────┬────────┘\n",
    "         │ stdio\n",
    "┌────────▼────────┐\n",
    "│  MCP Server     │  ← Serveur local (Python)\n",
    "└────────┬────────┘\n",
    "         │\n",
    "    ┌────┴────┬────────┬───────────┐\n",
    "    │          │        │           │\n",
    "  Tools   Resources  Prompts   Capabilities\n",
    "```"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Étape 1: Créer un serveur MCP local\n",
    "\n",
    "Créez un fichier `mcp_local_server.py`:\n",
    "\n",
    "```python\n",
    "#!/usr/bin/env python\n",
    "import json\n",
    "from mcp.server import Server\n",
    "from mcp.types import Tool, TextContent\n",
    "\n",
    "# Initialiser le serveur MCP\n",
    "server = Server(\"local-server\")\n",
    "\n",
    "# Ajouter un tool\n",
    "@server.call_tool()\n",
    "async def handle_tool_call(name: str, arguments: dict):\n",
    "    if name == \"get_info\":\n",
    "        return [{\"type\": \"text\", \"text\": f\"Info about {arguments.get('topic', 'unknown')}\"}]\n",
    "    return [{\"type\": \"text\", \"text\": f\"Unknown tool: {name}\"}]\n",
    "\n",
    "# Lister les tools disponibles\n",
    "@server.list_tools()\n",
    "async def list_tools():\n",
    "    return [\n",
    "        Tool(\n",
    "            name=\"get_info\",\n",
    "            description=\"Get information about a topic\",\n",
    "            inputSchema={\n",
    "                \"type\": \"object\",\n",
    "                \"properties\": {\n",
    "                    \"topic\": {\"type\": \"string\", \"description\": \"Topic to get info about\"}\n",
    "                },\n",
    "                \"required\": [\"topic\"]\n",
    "            }\n",
    "        )\n",
    "    ]\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    server.run()\n",
    "```\n",
    "\n",
    "Enregistrez ce fichier dans le dossier `resources/mcp_local_server.py`."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Étape 2: Créer un client MCP local"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Note: Ce code utilise async/await. En Jupyter, vous devez le structurer différemment.\n",
    "# Voici un exemple de comment le faire:\n",
    "\n",
    "print(\"\\n🔌 Initialisation du Client MCP Local\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "print(\"\"\"\n",
    "Pour utiliser un serveur MCP local, créez un client comme ceci:\n",
n",
    "```python\n",
    "from langchain_mcp_adapters.client import MultiServerMCPClient\n",
    "\n",
    "client = MultiServerMCPClient(\n",
    "    {\n",
    "        \"local_server\": {\n",
    "            \"transport\": \"stdio\",\n",
    "            \"command\": \"python\",\n",
    "            \"args\": [\"resources/mcp_local_server.py\"],\n",
    "        }\n",
    "    }\n",
    ")\n",
    "\n",
    "# Récupérer les tools disponibles\n",
    "tools = await client.get_tools()\n",
    "\n",
    "# Récupérer les resources\n",
    "resources = await client.get_resources(\"local_server\")\n",
    "\n",
    "# Récupérer les prompts\n",
    "prompts = await client.get_prompt(\"local_server\", \"prompt_name\")\n",
    "```\n",
    "\"\"\")\n",
    "\n",
    "print(\"\\nCaractéristiques:\")\n",
    "print(\"  - Transport: stdio (communication standard input/output)\")\n",
    "print(\"  - Idéal pour: Serveurs locaux personnalisés\")\n",
    "print(\"  - Performance: Excellente (local)\")\n",
    "print(\"  - Latence: Très faible\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Étape 3: Créer un agent avec le serveur MCP local"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\"\"\n",
    "Voici comment créer un agent avec un serveur MCP local:\n",
    "\n",
    "```python\n",
    "import asyncio\n",
    "from langchain.agents import create_agent\n",
    "from langchain_mcp_adapters.client import MultiServerMCPClient\n",
    "from langchain.messages import HumanMessage\n",
    "from langchain_ollama import ChatOllama\n",
    "\n",
    "async def main():\n",
    "    # Initialiser le client MCP\n",
    "    client = MultiServerMCPClient(\n",
    "        {\n",
    "            \"local_server\": {\n",
    "                \"transport\": \"stdio\",\n",
    "                \"command\": \"python\",\n",
    "                \"args\": [\"resources/mcp_local_server.py\"],\n",
    "            }\n",
    "        }\n",
    "    )\n",
    "    \n",
    "    # Récupérer les tools\n",
    "    tools = await client.get_tools()\n",
    "    \n",
    "    # Récupérer le prompt du serveur\n",
    "    prompts = await client.get_prompt(\"local_server\", \"system_prompt\")\n",
    "    system_prompt = prompts[0].content if prompts else \"You are a helpful assistant.\"\n",
    "    \n",
    "    # Initialiser le modèle\n",
    "    model = ChatOllama(\n",
    "        model=\"llama3.2:3b\",\n",
    "        temperature=0\n",
    "    )\n",
    "    \n",
    "    # Créer l'agent\n",
    "    agent = create_agent(\n",
    "        model=model,\n",
    "        tools=tools,\n",
    "        system_prompt=system_prompt\n",
    "    )\n",
    "    \n",
    "    # Poser une question\n",
    "    question = HumanMessage(content=\"Tell me about Python\")\n",
    "    response = await agent.ainvoke(\n",
    "        {\"messages\": [question]}\n",
    "    )\n",
    "    \n",
    "    print(response['messages'][-1].content)\n",
    "\n",
    "# Exécuter\n",
    "asyncio.run(main())\n",
    "```\n",
    "\n",
    "Pour exécuter: `uv run --active python agent_local_mcp.py`\n",
    "\"\"\")\n",
    "\n",
    "print(\"\\n✨ Avantages d'un serveur MCP local:\")\n",
    "print(\"  ✅ Complètement personnalisable\")\n",
    "print(\"  ✅ Pas de dépendances externes\")\n",
    "print(\"  ✅ Chargement dynamique de tools\")\n",
    "print(\"  ✅ Partage de resources et prompts\")"
   ]
  },
