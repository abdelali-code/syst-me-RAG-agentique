    "print(\"\"\"\n",
    "Exemple: Agent avec Local + Time + Travel servers\n",
    "\n",
    "```python\n",
    "async def main():\n",
    "    client = MultiServerMCPClient(\n",
    "        {\n",
    "            # Serveur local personnalisé\n",
    "            \"local\": {\n",
    "                \"transport\": \"stdio\",\n",
    "                \"command\": \"python\",\n",
    "                \"args\": [\"resources/mcp_local_server.py\"]\n",
    "            },\n",
    "            # Serveur de temps\n",
    "            \"time\": {\n",
    "                \"transport\": \"stdio\",\n",
    "                \"command\": \"uvx\",\n",
    "                \"args\": [\"mcp-server-time\", \"--local-timezone=Africa/Casablanca\"]\n",
    "            },\n",
    "            # Serveur distant de voyage\n",
    "            \"travel\": {\n",
    "                \"transport\": \"streamable_http\",\n",
    "                \"url\": \"https://mcp.kiwi.com\"\n",
    "            }\n",
    "        }\n",
    "    )\n",
    "    \n",
    "    # Tous les tools des 3 serveurs seront disponibles\n",
    "    tools = await client.get_tools()\n",
    "    \n",
    "    # Agent unique avec accès à tous les services\n",
    "    agent = create_agent(\n",
    "        model=model,\n",
    "        tools=tools,\n",
    "        system_prompt=\"You are an intelligent assistant with access to multiple services.\"\n",
    "    )\n",
    "    \n",
