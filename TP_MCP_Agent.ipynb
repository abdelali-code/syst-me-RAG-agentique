   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🚀 Bonnes pratiques MCP\n",
    "\n",
    "### 1. Gestion des erreurs\n",
    "```python\n",
    "try:\n",
    "    tools = await client.get_tools()\nexcept Exception as e:\n",
    "    print(f\"Erreur lors de la récupération des tools: {e}\")\n",
    "```\n",
    "\n",
    "### 2. Timeouts et limitations\n",
    "```python\n",
    "# Définir un timeout pour les appels distants\n",
    "import asyncio\n",
    "try:\n",
    "    response = await asyncio.wait_for(agent.ainvoke(...), timeout=30)\nexcept asyncio.TimeoutError:\n",
    "    print(\"Timeout: le serveur n'a pas répondu à temps\")\n",
    "```\n",
    "\n",
    "### 3. Logging et monitoring\n",
    "```python\n",
    "import logging\n",
    "logging.basicConfig(level=logging.DEBUG)\n",
    "# Sera utile pour debugger les connexions MCP\n",
    "```\n",
    "\n",
    "### 4. Cache des tools\n",
    "```python\n",
    "# Récupérer les tools une seule fois et les réutiliser\n",
    "tools = await client.get_tools()  # Une seule fois\n",
    "for question in many_questions:\n",
    "    # Réutiliser les outils\n",
    "    response = await agent.ainvoke({\"messages\": [HumanMessage(content=question)]})\n",
    "```\n",
    "\n",
    "### 5. Mémoire et état\n",
    "```python\n",
    "# Utiliser InMemorySaver pour les conversations longues\n",
    "from langgraph.checkpoint.memory import InMemorySaver\n",
    "agent = create_agent(\n",
    "    model=model,\n",
    "    tools=tools,\n",
    "    checkpointer=InMemorySaver()  # Maintient le contexte\n",
    ")\n",
    "```"
   ]
