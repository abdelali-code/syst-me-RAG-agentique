    "import socket\n",
    "import sys\n",
    "\n",
    "def check_ollama_connection():\n",
    "    \"\"\"Vérifier si Ollama est accessible sur localhost:11434\"\"\"\n",
    "    try:\n",
    "        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n",
    "        sock.settimeout(2)\n",
    "        result = sock.connect_ex(('127.0.0.1', 11434))\n",
    "        sock.close()\n",
    "        \n",
    "        if result == 0:\n",
    "            print(\"✅ Ollama est accessible sur http://localhost:11434\")\n",
    "            return True\n",
    "        else:\n",
    "            print(\"❌ Ollama n'est pas accessible\")\n",
    "            print(\"   Assurez-vous que Ollama est démarré: 'ollama serve'\")\n",
    "            return False\n",
    "    except Exception as e:\n",
    "        print(f\"❌ Erreur lors de la vérification: {e}\")\n",
    "        return False\n",
    "\n",
    "ollama_running = check_ollama_connection()"
   ]
