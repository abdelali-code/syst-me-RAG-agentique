    "## 9. Agent avec mémoire\n",
    "\n",
    "Avec mémoire, l'agent peut maintenir le contexte à travers plusieurs interactions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from langgraph.checkpoint.memory import InMemorySaver\n",
    "\n",
    "# Créer un agent avec mémoire\n",
    "agent_with_memory = create_agent(\n",
    "    model=model,\n",
    "    checkpointer=InMemorySaver(),  # Checkpointer pour la mémoire\n",
    ")\n",
    "\n",
    "# Configuration: utiliser un thread_id pour maintenir la conversation\n",
    "config = {\"configurable\": {\"thread_id\": \"1\"}}\n",
    "\n",
    "# Premier message - présentation\n",
    "message1 = HumanMessage(content=\"Bonjour, mon nom est Sami et je suis un développeur.\")\n",
    "response1 = agent_with_memory.invoke(\n",
    "    {\"messages\": [message1]},\n",
    "    config,  # Passer la configuration\n",
    ")\n",
    "\n",
    "print(\"Réponse 1:\")\n",
    "print(response1['messages'][-1].content)\n",
    "print()"
   ]
