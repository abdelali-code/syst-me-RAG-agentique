    "load_dotenv()\n",
    "\n",
    "# Initialiser le client Tavily\n",
    "try:\n",
    "    tavily_client = TavilyClient(api_key=os.getenv(\"TAVILY_API_KEY\"))\n",
    "    \n",
    "    # Définir le web search tool\n",
    "    @tool\n",
    "    def web_search(query: str) -> Dict[str, Any]:\n",
    "        \"\"\"Effectue une recherche web avec Tavily.\n",
    "        \n",
    "        Args:\n",
    "            query: La requête de recherche\n",
    "        \"\"\"\n",
    "        return tavily_client.search(query)\n",
    "    \n",
    "    print(\"Web search tool créé avec succès\")\nexcept Exception as e:\n",
    "    print(f\"Note: Tavily API non configurée. Erreur: {e}\")\n",
    "    print(\"Pour utiliser le Web Search, configurez TAVILY_API_KEY dans .env\")"
