   "outputs": [],
   "source": [
    "# Deuxième message - question qui dépend de la première\n",
    "message2 = HumanMessage(content=\"Quel est mon métier ?\")\n",
    "response2 = agent_with_memory.invoke(\n",
    "    {\"messages\": [message2]},\n",
    "    config,  # Utiliser la même configuration (même thread_id)\n",
    ")\n",
    "\n",
    "print(\"Réponse 2 (avec mémoire):\")\n",
    "print(response2['messages'][-1].content)\n",
    "print(\"\\nRemarque: L'agent se souvient maintenant de la présentation précédente\")"
