   "source": [
    "## 5. Agent avec réponse structurée en utilisant BaseModel\n",
    "\n",
    "Utiliser Pydantic BaseModel pour rendre la réponse facile à exploiter automatiquement."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pydantic import BaseModel\n",
    "\n",
    "# Définir la structure de réponse avec BaseModel\n",
    "class CapitalInfo(BaseModel):\n",
    "    nom: str\n",
    "    localisation: str\n",
    "    ambiance: str\n",
    "    economie: str\n",
    "\n",
    "print(f\"Modèle CapitalInfo défini avec les champs: {CapitalInfo.model_fields.keys()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Créer un agent avec réponse structurée en BaseModel\n",
    "agent_basemodel = create_agent(\n",
    "    model=model,\n",
    "    system_prompt=system_prompt_structured,\n",
    "    response_format=CapitalInfo\n",
    ")\n",
    "\n",
    "response = agent_basemodel.invoke(\n",
    "    {\"messages\": [question]}\n",
    ")\n",
    "\n",
    "# Accéder à la réponse structurée\n",
    "structured_response = response.get(\"structured_response\")\n",
    "print(\"Réponse structurée en BaseModel:\")\n",
    "print(f\"Type: {type(structured_response)}\")\n",
    "if structured_response:\n",
    "    print(f\"Nom: {structured_response.nom}\")\n",
    "    print(f\"Localisation: {structured_response.localisation}\")\n",
    "    print(f\"Ambiance: {structured_response.ambiance}\")\n",
    "    print(f\"Économie: {structured_response.economie}\")"
   ]
