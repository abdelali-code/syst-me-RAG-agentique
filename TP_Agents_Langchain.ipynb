    "## 6. Les Tools (Outils)\n",
    "\n",
    "Les tools permettent à l'agent d'appeler des fonctions externes pour effectuer des actions."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 6.1 Création d'un Tool"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from langchain.tools import tool\n",
    "\n",
    "# Définir un tool personnalisé\n",
    "@tool(\"meteo_capitale\")\n",
    "def meteo_capitale(ville: str) -> str:\n",
    "    \"\"\"\n",
    "    Donne la météo d'une capitale (valeurs fixes pour test).\n",
    "    \n",
    "    Args:\n",
    "        ville: nom de la capitale\n",
    "    \"\"\"\n",
    "    print(f\"Tool 'meteo_capitale' utilisé pour: {ville}\")\n",
    "    temperature = 25\n",
    "    humidite = 60\n",
    "    pression = 1013\n",
    "    return (\n",
    "        f\"Météo à {ville} : \"\n",
    "        f\"Température = {temperature}°C, \"\n",
    "        f\"Humidité = {humidite}%, \"\n",
    "        f\"Pression = {pression} hPa\"\n",
    "    )\n",
    "\n",
    "# Tester le tool\n",
    "result = meteo_capitale.invoke(\"Capitole Lunaire\")\n",
    "print(f\"Résultat: {result}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 6.2 Ajout du Tool à l'agent"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Créer un agent avec un tool\n",
    "system_prompt_with_tools = \"Utilises les tools pour répondre aux questions\"\n",
    "\n",
    "agent_with_tools = create_agent(\n",
    "    model=model,\n",
    "    tools=[meteo_capitale],\n",
    "    system_prompt=system_prompt_with_tools,\n",
    ")\n",
    "\n",
    "# Poser une question qui nécessite l'utilisation du tool\n",
    "question_meteo = HumanMessage(content=\"Quelle est la météo à Capitole lunaire ?\")\n",
    "response = agent_with_tools.invoke(\n",
    "    {\"messages\": [question_meteo]}\n",
    ")\n",
    "\n",
    "print(\"Réponse de l'agent avec tool:\")\n",
    "print(response['messages'][-1].content)"
   ]
  },
