    "\n",
    "response = scifi_structured_agent.invoke(\n",
    "    {\"messages\": [question]}\n",
    ")\n",
    "\n",
    "print(\"Réponse structurée:\")\n",
    "print(response['messages'][-1].content)"
   ]
