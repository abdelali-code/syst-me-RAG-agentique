   "source": [
    "## 10. TP: Chef personnel\n",
    "\n",
    "### Objectif\n",
    "Concevoir un agent intelligent jouant le rôle d'un chef cuisinier personnel capable de:\n",
    "- Recevoir la liste des ingrédients disponibles\n",
    "- Mémoriser les préférences de l'utilisateur\n",
    "- Utiliser la recherche web pour compléter ses connaissances culinaires\n",
    "- Proposer des plats adaptés aux ingrédients disponibles\n",
    "\n",
    "### Implémentation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Définir un tool pour rechercher des recettes\n",
    "@tool(\"recherche_recette\")\n",
    "def recherche_recette(ingredients: str, preferences: str = \"\") -> str:\n",
    "    \"\"\"\n",
    "    Recherche des recettes basées sur les ingrédients disponibles.\n",
    "    \n",
    "    Args:\n",
    "        ingredients: Liste des ingrédients disponibles\n",
    "        preferences: Préférences culinaires de l'utilisateur\n",
    "    \"\"\"\n",
    "    print(f\"Tool recherche_recette utilisé\")\n",
    "    print(f\"Ingrédients: {ingredients}\")\n",
    "    print(f\"Préférences: {preferences}\")\n",
    "    \n",
